# =========================================================================
# بيت الصحافة (PressHouse) - ملف متغيرات البيئة الشامل والموحد
# PressHouse - Comprehensive & Unified Environment Variables Template
# =========================================================================

# 1. إعدادات النظام الأساسية والنطاق (Core System & Domain Settings)
NODE_ENV=production
PORT=3000
DOMAIN=ph-ye.org
APP_PATH=/Data/presshouse
VITE_DOMAIN=ph-ye.org
VITE_API_URL=api.ph-ye.org

# 2. حسابات الإدارة وبذر البيانات المعتمدة (System Accounts & Core Seed Identities)
DEFAULT_ADMIN_PASSWORD=
ROOT_ADMIN_EMAIL=raidan@ph-ye.org
ROOT_ADMIN_PASSWORD=
SYSTEM_ADMIN_EMAIL=admin@ph-ye.org
SYSTEM_NO_REPLY_EMAIL=no-replay@ph-ye.org
SYSTEM_REGISTER_EMAIL=register@ph-ye.org
SYSTEM_ASSISTANT_EMAIL=assistant@ph-ye.org
ADMIN_NOTIFICATION_EMAIL=raidan@ph-ye.org

# 3. مفاتيح الأمان وجلسات التوثيق (Security, Encryption & Sessions)
JWT_SECRET=
AI_API_KEY=
AI_BASE_URL=https://integrate.api.nvidia.com/v1
FIRECRAWL_API_KEY=
GEMINI_API_KEY=
VITE_ADMIN_PATH=/admin
VITE_ROOT_PATH=/root
ENCRYPTION_KEY=
API_RATE_LIMIT_KEY=
SESSION_SECRET=
WEBHOOK_SECRET=
CRON_SECRET=

# 4. تكاملات الذكاء الاصطناعي - AI Engines & Platforms
AI_ENABLED=true
AI_MODEL_PRIMARY=z-ai/glm-5.2

# 5. خوادم البريد الإلكتروني والمستضيف المعتمد (SMTP Mail Services Setup)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="بيت الصحافة <web@ph-ye.org>"

# 6. تكاملات تليجرام وبوتات الرصد الفوري (Telegram Bot Security & Alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# 7. قاعدة البيانات PostgreSQL (Optional if using default SQLite)
POSTGRES_URL=

# 8. مفاتيح API للمصادقة والترخيص (API Authentication Keys)
API_KEY_PUBLISHER=
API_KEY_ADMIN=
API_KEY_WEBHOOK=
